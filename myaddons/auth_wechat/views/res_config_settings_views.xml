<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- WeChat Login Configuration in General Settings -->
    <record id="res_config_settings_view_form_wechat" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.auth.wechat</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="微信登录" string="微信登录" name="auth_wechat">
                    <block title="微信登录设置" name="wechat_login_settings">
                        <setting id="wechat_login_enabled" string="微信扫码登录" help="启用后登录页将显示微信扫码登录按钮">
                            <field name="wechat_login_enabled" />
                        </setting>
                        <setting id="wechat_app_id" string="微信AppID" help="微信开放平台网站应用的AppID">
                            <field name="wechat_app_id" placeholder="wx1234567890abcdef" />
                        </setting>
                        <setting id="wechat_app_secret" string="微信AppSecret" help="微信开放平台网站应用的AppSecret">
                            <field name="wechat_app_secret" password="True" placeholder="请输入AppSecret" />
                        </setting>
                        <setting id="temp_user_enabled" string="访客自动登录" help="启用后未登录用户将自动创建临时账号使用翻译功能">
                            <field name="temp_user_enabled" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
