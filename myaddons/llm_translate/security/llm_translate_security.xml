<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Record rule: users can only see their own translations -->
    <record id="llm_translation_rule_user" model="ir.rule">
        <field name="name">LLM Translation: own records only</field>
        <field name="model_id" ref="model_llm_translation" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <!-- LLM Manager can see all translations -->
    <record id="llm_translation_rule_manager" model="ir.rule">
        <field name="name">LLM Translation: manager sees all</field>
        <field name="model_id" ref="model_llm_translation" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('llm.group_llm_manager'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <!-- Portal/temp users can only see their own translations -->
    <record id="llm_translation_rule_portal" model="ir.rule">
        <field name="name">LLM Translation: portal own records</field>
        <field name="model_id" ref="model_llm_translation" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- Portal/temp users can access translation lines of own translations -->
    <record id="llm_translation_line_rule_portal" model="ir.rule">
        <field name="name">LLM Translation Line: portal own records</field>
        <field name="model_id" ref="model_llm_translation_line" />
        <field name="domain_force">[('translation_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- Portal/temp users can access their own llm threads -->
    <record id="llm_thread_rule_portal" model="ir.rule">
        <field name="name">LLM Thread: portal own records</field>
        <field name="model_id" ref="llm_thread.model_llm_thread" />
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="False" />
    </record>
</odoo>
