<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ================================================================ -->
    <!-- Tree/List View -->
    <!-- ================================================================ -->
    <record id="llm_translation_view_list" model="ir.ui.view">
        <field name="name">llm.translation.list</field>
        <field name="model">llm.translation</field>
        <field name="arch" type="xml">
            <list string="Translations" default_order="create_date desc">
                <field name="name" />
                <field name="source_filename" string="Source File" />
                <field name="source_lang" />
                <field name="target_lang" />
                <field name="provider_id" />
                <field name="model_id" />
                <field name="project_id" />
                <field name="progress" widget="progressbar" />
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'extracting'"
                    decoration-primary="state == 'translating'"
                    decoration-success="state == 'done'"
                    decoration-danger="state == 'error'" />
                <field name="source_file_size_display" string="大小" />
                <field name="create_date" string="Created" />
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Form View -->
    <!-- ================================================================ -->
    <record id="llm_translation_view_form" model="ir.ui.view">
        <field name="name">llm.translation.form</field>
        <field name="model">llm.translation</field>
        <field name="arch" type="xml">
            <form string="Translation">
                <header>
                    <button name="action_start_translation"
                        string="Start Translation"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('draft',)"
                        confirm="Start translating all pending paragraphs?" />
                    <button name="action_start_translation"
                        string="Resume Translation"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('translating', 'error')" />
                    <button name="action_retry_errors"
                        string="Retry Failed"
                        type="object"
                        class="btn-warning"
                        invisible="state != 'error'" />
                    <button name="action_download_result"
                        string="Download Translation"
                        type="object"
                        class="btn-success"
                        invisible="state not in ('done', 'error')" />
                    <button name="action_reset_to_draft"
                        string="Reset to Draft"
                        type="object"
                        invisible="state not in ('error', 'done')"
                        confirm="Reset translation? Progress will be kept." />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,translating,done" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Translation Name..." />
                        </h1>
                    </div>

                    <!-- Configuration -->
                    <group>
                        <group string="LLM Configuration">
                            <field name="provider_id" />
                            <field name="model_id" />
                            <field name="knowledge_collection_id"
                                options="{'no_create': True}" />
                        </group>
                        <group string="Translation Settings">
                            <field name="source_lang" />
                            <field name="source_lang_custom"
                                invisible="source_lang != 'other'" />
                            <field name="target_lang" />
                            <field name="target_lang_custom"
                                invisible="target_lang != 'other'" />
                            <field name="project_id"
                                options="{'no_create': True}" />
                        </group>
                    </group>

                    <!-- File Info -->
                    <group>
                        <group string="Source Document">
                            <field name="source_attachment_id"
                                filename="source_filename" />
                            <field name="source_filename" invisible="1" />
                        </group>
                        <group string="Translated Document">
                            <field name="result_attachment_id"
                                filename="result_filename"
                                readonly="1" />
                            <field name="result_filename" invisible="1" />
                        </group>
                    </group>

                    <!-- Progress -->
                    <group string="Progress" invisible="state == 'draft'">
                        <group>
                            <field name="progress" widget="progressbar" />
                        </group>
                        <group>
                            <field name="total_lines" />
                            <field name="translated_lines" />
                        </group>
                    </group>

                    <!-- Error Message -->
                    <group invisible="not error_message">
                        <field name="error_message"
                            class="text-danger"
                            readonly="1" />
                    </group>

                    <!-- Translation Lines (side by side) -->
                    <notebook invisible="not line_ids">
                        <page string="Translation Content" name="content">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom"
                                    decoration-muted="is_empty"
                                    decoration-danger="state == 'error'"
                                    decoration-success="state == 'done'"
                                    default_order="sequence">
                                    <field name="sequence" widget="handle" />
                                    <field name="source_text"
                                        readonly="1"
                                        string="Original" />
                                    <field name="translated_text"
                                        string="Translation" />
                                    <field name="state" widget="badge"
                                        decoration-info="state == 'pending'"
                                        decoration-primary="state == 'translating'"
                                        decoration-success="state == 'done'"
                                        decoration-danger="state == 'error'" />
                                    <field name="is_empty" column_invisible="1" />
                                    <field name="estimated_tokens"
                                        string="Tokens"
                                        optional="hide" />
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <!-- Hidden fields -->
                    <field name="user_id" invisible="1" />
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Search View -->
    <!-- ================================================================ -->
    <record id="llm_translation_view_search" model="ir.ui.view">
        <field name="name">llm.translation.search</field>
        <field name="model">llm.translation</field>
        <field name="arch" type="xml">
            <search string="Translations">
                <field name="name" />
                <field name="source_lang" />
                <field name="target_lang" />
                <field name="provider_id" />
                <field name="project_id" />
                <filter name="filter_draft" string="Draft"
                    domain="[('state', '=', 'draft')]" />
                <filter name="filter_translating" string="In Progress"
                    domain="[('state', '=', 'translating')]" />
                <filter name="filter_done" string="Completed"
                    domain="[('state', '=', 'done')]" />
                <filter name="filter_error" string="Errors"
                    domain="[('state', '=', 'error')]" />
                <separator />
                <filter name="filter_my" string="My Translations"
                    domain="[('user_id', '=', uid)]" />
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                        context="{'group_by': 'state'}" />
                    <filter name="group_project" string="Project"
                        context="{'group_by': 'project_id'}" />
                    <filter name="group_provider" string="Provider"
                        context="{'group_by': 'provider_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Client Action (for the frontend split-view) -->
    <!-- ================================================================ -->
    <record id="action_llm_translation_client" model="ir.actions.client">
        <field name="name">Translation</field>
        <field name="tag">llm_translate.translation_view</field>
    </record>

    <!-- Standard List/Form Action -->
    <record id="action_llm_translation" model="ir.actions.act_window">
        <field name="name">Translations</field>
        <field name="res_model">llm.translation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="llm_translation_view_search" />
        <field name="context">{'search_default_filter_my': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first translation task
            </p>
            <p>
                Upload a Word document (.doc/.docx), PowerPoint presentation (.ppt/.pptx), or PDF (.pdf) and translate it using AI.
                The knowledge base glossary will ensure consistent terminology.
            </p>
        </field>
    </record>

</odoo>
